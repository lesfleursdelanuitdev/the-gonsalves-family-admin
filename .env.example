# Database: required for login and admin CRUD. Copy from ligneous-frontend/.env.local.
# Use a role with INSERT/UPDATE/DELETE (e.g. ligneous_user), not the public site's gonsalves_readonly user.
# DATABASE_URL="postgresql://ligneous_user:YOUR_PASSWORD@localhost:5432/ligneous_frontend?sslmode=disable"

# Admin tree: which tree this app edits. Set ONE of these (required for Individuals, Families, Events, Media).
# - ADMIN_TREE_ID = Tree.id (UUID from the trees table)
# - ADMIN_TREE_FILE_ID = GedcomFile.fileId (string from gedcom_files table)
# Run GET /api/admin/setup when logged in to see suggested values from your database.
# ADMIN_TREE_ID=
# ADMIN_TREE_FILE_ID=

# Production uploads must be under /mnt/ (see lib/admin/media-upload-storage.ts). Recommended path:
#   <ADMIN_MEDIA_FILES_ROOT>/gedcom-admin/{images|documents|audio}/   (new uploads)
#   <ADMIN_MEDIA_FILES_ROOT>/gedcom-admin/                            (legacy single-segment URLs)
# If unset in production, the app defaults to /mnt/storage/uploads.
# Served at https://admin…/uploads/gedcom-admin/… via this app (or nginx alias to the same folder).
#
# ADMIN_MEDIA_FILES_ROOT="/mnt/storage/uploads"
#
# After pointing this at new storage, copy files and fix DB paths:
#   npm run migrate-admin-uploads -- --dry-run
#   npm run migrate-admin-uploads -- --source-parent ./public/uploads --dest-parent /mnt/storage/uploads

# GEDCOM lib HTTP API (ligneous-gedcom-lib-api). Server-side only — used by /api/admin/export and similar routes.
# Default in code if unset: http://localhost:8092
# Production (same host, API bound to loopback): http://127.0.0.1:8092
# Production (TLS subdomain): https://gedcom-api.example.com
# LIB_API_URL="http://127.0.0.1:8092"

# Optional
# NEXT_PUBLIC_LIGNOUS_FRONTEND_URL="http://localhost:4000"
