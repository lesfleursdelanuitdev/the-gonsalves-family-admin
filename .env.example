# Database: required for login and admin CRUD. Copy from ligneous-frontend/.env.local.
# Use a role with INSERT/UPDATE/DELETE (e.g. ligneous_user), not the public site's gonsalves_readonly user.
# DATABASE_URL="postgresql://ligneous_user:YOUR_PASSWORD@localhost:5432/ligneous_frontend?sslmode=disable"
#
# Production DB migrations from your laptop (optional): point Prisma at prod, then from repo root:
#   cd packages/ligneous-prisma && DATABASE_URL="postgresql://WRITER@prod-host:5432/ligneous_frontend?sslmode=require" npx prisma migrate deploy
# Multiple URLs (deduped by host:port/dbname): see packages/ligneous-prisma/scripts/migrate-deploy-all.mjs
#   export PRISMA_MIGRATE_DATABASE_URLS="postgresql://…"
#   npm run db:migrate:all
# The production server should set DATABASE_URL in .env.production (not committed) before `./scripts/deploy.sh`, which runs `prisma migrate deploy` then build + pm2 restart.

# Admin tree: which tree this app edits. Set ONE of these (required for Individuals, Families, Events, Media).
# - ADMIN_TREE_ID = Tree.id (UUID from the trees table)
# - ADMIN_TREE_FILE_ID = GedcomFile.fileId (string from gedcom_files table)
# Run GET /api/admin/setup when logged in to see suggested values from your database.
# ADMIN_TREE_ID=
# ADMIN_TREE_FILE_ID=

# Production uploads must be under /mnt/ (see lib/admin/media-upload-storage.ts). Recommended path:
#   <ADMIN_MEDIA_FILES_ROOT>/gedcom-admin/{images|documents|audio}/   (new uploads)
#   <ADMIN_MEDIA_FILES_ROOT>/gedcom-admin/                            (legacy single-segment URLs)
# If unset in production, the app defaults to /mnt/storage/uploads.
# Served at https://admin…/uploads/gedcom-admin/… via this app (or nginx alias to the same folder).
#
# ADMIN_MEDIA_FILES_ROOT="/mnt/storage/uploads"
#
# After pointing this at new storage, copy files and fix DB paths:
#   npm run migrate-admin-uploads -- --dry-run
#   npm run migrate-admin-uploads -- --source-parent ./public/uploads --dest-parent /mnt/storage/uploads

# GEDCOM lib HTTP API (ligneous-gedcom-lib-api). Server-side only — used by /api/admin/export, /api/admin/gedcom/validate/*, etc.
# Default in code if unset: http://localhost:8092
# Production (same host, API bound to loopback): http://127.0.0.1:8092
# Production (TLS subdomain): https://gedcom-api.example.com
# LIB_API_URL="http://127.0.0.1:8092"

# Python research API (used by /api/research/[...path] proxy in this app)
# PYTHON_API_URL="http://127.0.0.1:5001"

# Optional
# NEXT_PUBLIC_LIGNOUS_FRONTEND_URL="http://localhost:4000"

# Public family site: statistics preview route (no trailing slash). Used by admin Data Viewer “Statistics”
# (opens a new tab with a hash to the matching research analytics section, e.g. #stats-individuals).
# Example local: http://localhost:3000/statistics-test
# NEXT_PUBLIC_RESEARCH_STATISTICS_URL="http://localhost:3000/statistics-test"

# Shared auth cookie contract (used by admin + public site adapters).
# Keep values identical across both apps in production.
# AUTH_COOKIE_NAME="gonsalves_session"
# AUTH_COOKIE_DOMAIN=".gonsalvesfamily.com"   # Leave unset for localhost/dev.
# AUTH_COOKIE_SECURE="true"                   # Optional override; defaults by NODE_ENV.
# Hard cutover note: if these values change, previous sessions are not reused and users must sign in again.
